# Claude Code workspace metadata (worktrees, settings, etc.)
.claude/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Training artefacts — large and reproducible
captures/
runs/
*.wav
labels.csv

# Host build outputs from firmware/host_build (regenerated by make)
firmware/host_build/*.so
firmware/host_build/*.dll
firmware/host_build/*.dylib
firmware/host_build/*.a

# MCUXpresso for VS Code build / SDK-clone artefacts under each project
# (CMakePresets → ${fileDir}/<preset>/ holds compile output;
#  __repo__/ holds west-managed clones of mcuxsdk + manifests.)
**/debug/
**/release/
**/flash_debug/
**/flash_release/
**/__repo__/
**/mcuxsdk/
**/manifests/
**/.west/

# MCUXpresso for VS Code per-machine config (contains absolute SDK / toolchain /
# user-home paths that differ per developer). Created by the extension's Import
# Project wizard on first open of each project; should not live in version
# control. See firmware/README.md "ビルド手順" for first-clone bring-up.
firmware/projects/*/.vscode/mcuxpresso-tools.json
firmware/projects/*/mcux_include.json

# Editor / OS detritus
.DS_Store
Thumbs.db
*.swp
*~

# Conda lock / env exports (kept out by default — regenerate per machine)
pc/environment-lock.yml
pc/env-conda.yml
pc/env-pip.txt
