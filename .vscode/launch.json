{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "PC: receiver — serial (COM7)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pc/receiver.py",
      "args": [
        "--port", "COM7",
        "--baud", "921600",
        "--out", "${workspaceFolder}/captures",
        "--max-frames", "20"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/pc",
      "justMyCode": true
    },
    {
      "name": "PC: verify — serial (COM7, strict 100 frames)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pc/verify.py",
      "args": [
        "--port", "COM7",
        "--baud", "921600",
        "--frames", "100",
        "--strict"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/pc",
      "justMyCode": true
    },
    {
      "name": "PC: verify — file loopback",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pc/verify.py",
      "args": [
        "--in", "${workspaceFolder}/captures/loopback.bin",
        "--strict"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/pc"
    },
    {
      "name": "PC: emulator — write 20 frames to file",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pc/emulator.py",
      "args": [
        "--out", "${workspaceFolder}/captures/loopback.bin",
        "--frames", "20",
        "--cadence", "0"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/pc"
    },
    {
      "name": "PC: emulator — TCP server (port 5000)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pc/emulator.py",
      "args": [
        "--tcp", "127.0.0.1:5000",
        "--cadence", "0.5",
        "--frames", "20"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/pc"
    },
    {
      "name": "PC: run all unittests",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": [
        "discover",
        "-s", ".",
        "-p", "test_*.py",
        "-v"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/pc"
    },
    {
      "name": "PC: training — smoke run model.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pc/training/model.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/pc/training"
    }
  ]
}
